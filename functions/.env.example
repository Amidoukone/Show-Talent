# Shared non-secret defaults committed to git.
# Do not put live secrets here.
APP_ENV=production
ENFORCE_APPCHECK=false
STORAGE_BUCKET=your-default-storage-bucket
OPTIMIZE_TRIGGER_REGION=europe-west1
VIDEO_UPLOADS_ENABLED=false
MAX_VIDEO_UPLOADS_PER_DAY=3
MAX_CONCURRENT_VIDEO_UPLOADS=1
MAX_OPTIMIZE_FILE_SIZE_BYTES=62914560
UNVERIFIED_ACCOUNT_RETENTION_DAYS=3
UNVERIFIED_PURGE_EXCLUDE_MANAGED=true
# Optional: public web host used as continue URL in Firebase auth action links.
# If empty, links are generated without continue URL to avoid broken redirects.
EMAIL_LINK_CUSTOM_HOST=
