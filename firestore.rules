rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function hasUserDoc(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    // authDisabled is the only remaining hard access stop.
    function hasActiveAccount(uid) {
      return hasUserDoc(uid) &&
        userDoc(uid).data.authDisabled != true;
    }

    function signedInAndActive() {
      return signedIn() && hasActiveAccount(request.auth.uid);
    }

    function userRole() {
      return signedIn() && hasUserDoc(request.auth.uid) ?
        userDoc(request.auth.uid).data.role :
        null;
    }

    function isPublicSignupRole(role) {
      return role == "joueur" || role == "fan";
    }

    function isOpportunityPublisherRole(role) {
      return role == "recruteur" || role == "club" || role == "agent";
    }

    function isRecruiterOrClub() {
      return signedInAndActive() && isOpportunityPublisherRole(userRole());
    }

    function isSignedInPlayer() {
      return signedInAndActive() && userRole() == "joueur";
    }

    function isAdminOperator() {
      return signedIn() &&
        (
          userRole() == "admin" ||
          request.auth.token.admin == true ||
          request.auth.token.platformAdmin == true ||
          request.auth.token.superAdmin == true
        );
    }

    function preservesUserIdentity() {
      return request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.createdByAdmin == resource.data.createdByAdmin;
    }

    function preservesProtectedUserFields() {
      return request.resource.data.dateInscription == resource.data.dateInscription &&
        request.resource.data.authDisabled == resource.data.authDisabled &&
        request.resource.data.authDisabledAt == resource.data.authDisabledAt &&
        request.resource.data.authDisabledBy == resource.data.authDisabledBy &&
        request.resource.data.authDisabledReason == resource.data.authDisabledReason &&
        request.resource.data.invitedBy == resource.data.invitedBy &&
        request.resource.data.invitedAt == resource.data.invitedAt &&
        request.resource.data.lastInviteAt == resource.data.lastInviteAt &&
        request.resource.data.roleChangedBy == resource.data.roleChangedBy &&
        request.resource.data.roleChangedAt == resource.data.roleChangedAt &&
        request.resource.data.updatedByAdmin == resource.data.updatedByAdmin;
    }

    function expectedVerifiedActiveState() {
      return request.resource.data.authDisabled != true;
    }

    function preservesVerificationState() {
      return request.auth.token.email_verified == true ?
        request.resource.data.emailVerified == true &&
          request.resource.data.estActif == expectedVerifiedActiveState() &&
          (
            request.resource.data.emailVerifiedAt == resource.data.emailVerifiedAt ||
            request.resource.data.emailVerifiedAt == request.time
          ) :
        request.resource.data.emailVerified == resource.data.emailVerified &&
          request.resource.data.estActif == resource.data.estActif &&
          request.resource.data.emailVerifiedAt == resource.data.emailVerifiedAt;
    }

    function changesOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function canMutateOfferCandidates() {
      return isSignedInPlayer() &&
        resource.data.recruteur.uid != request.auth.uid &&
        resource.data.statut == "ouverte" &&
        changesOnly(["candidats", "lastUpdated"]);
    }

    function canMutateOfferViews() {
      return signedInAndActive() &&
        resource.data.recruteur.uid != request.auth.uid &&
        changesOnly(["vues", "viewedBy", "lastUpdated"]);
    }

    function canMutateEventParticipants() {
      return isSignedInPlayer() &&
        resource.data.organisateur.uid != request.auth.uid &&
        resource.data.statut == "ouvert" &&
        changesOnly(["participants", "lastUpdated"]);
    }

    match /users/{userId} {
      allow read: if signedIn() &&
        (hasActiveAccount(request.auth.uid) || isOwner(userId));
      allow create: if isOwner(userId) &&
        request.resource.data.uid == request.auth.uid &&
        isPublicSignupRole(request.resource.data.role) &&
        request.resource.data.createdByAdmin != true;
      allow update: if isOwner(userId) &&
        hasActiveAccount(request.auth.uid) &&
        preservesUserIdentity() &&
        preservesProtectedUserFields() &&
        preservesVerificationState();
      allow delete: if isOwner(userId);
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if signedInAndActive() &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedInAndActive() &&
        resource.data.uid == request.auth.uid;
    }

    match /offres/{offreId} {
      allow read: if signedInAndActive();
      allow create: if isRecruiterOrClub() &&
        request.resource.data.recruteur.uid == request.auth.uid;
      allow update: if signedInAndActive() &&
        (
          resource.data.recruteur.uid == request.auth.uid ||
          canMutateOfferCandidates() ||
          canMutateOfferViews()
        );
      allow delete: if signedInAndActive() &&
        resource.data.recruteur.uid == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if signedInAndActive();
      allow create: if isRecruiterOrClub() &&
        request.resource.data.organisateur.uid == request.auth.uid;
      allow update: if signedInAndActive() &&
        (
          resource.data.organisateur.uid == request.auth.uid ||
          canMutateEventParticipants()
        );
      allow delete: if signedInAndActive() &&
        resource.data.organisateur.uid == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow read: if signedInAndActive() &&
        request.auth.uid in resource.data.utilisateurIds;
      allow create: if signedInAndActive() &&
        request.auth.uid in request.resource.data.utilisateurIds &&
        request.resource.data.utilisateurIds.size() == 2;
      allow update, delete: if signedInAndActive() &&
        request.auth.uid in resource.data.utilisateurIds;

      match /messages/{messageId} {
        allow read: if signedInAndActive() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.utilisateurIds;
        allow create: if signedInAndActive() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.utilisateurIds &&
          request.resource.data.expediteurId == request.auth.uid;
        allow update, delete: if signedInAndActive() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.utilisateurIds;
      }
    }

    match /contact_intakes/{intakeId} {
      allow read: if signedInAndActive() &&
        (
          resource.data.requesterUid == request.auth.uid ||
          resource.data.targetUid == request.auth.uid ||
          isAdminOperator()
        );
      allow create: if signedInAndActive() &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.targetUid is string &&
        request.resource.data.targetUid != request.auth.uid &&
        request.resource.data.status == "new" &&
        request.resource.data.agencyFollowUpStatus == "new" &&
        request.resource.data.contactReason is string &&
        request.resource.data.introMessage is string;
      allow update, delete: if isAdminOperator();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Server-only collections
    match /client_logs/{docId} {
      allow read, write: if false;
    }

    match /video_action_logs/{docId} {
      allow read, write: if false;
    }

    match /video_share_limits/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
