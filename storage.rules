rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function videoDocIdFromFileName(fileName) {
      return fileName[0:fileName.size() - 4];
    }

    function thumbnailDocIdFromJpgFileName(fileName) {
      return fileName[10:fileName.size() - 4];
    }

    function thumbnailDocIdFromJpegFileName(fileName) {
      return fileName[10:fileName.size() - 5];
    }

    function isOwnedVideoDoc(videoId) {
      return firestore.exists(/databases/(default)/documents/videos/$(videoId)) &&
        firestore.get(/databases/(default)/documents/videos/$(videoId)).data.uid == request.auth.uid;
    }

    function isOwnedVideoMp4(fileName) {
      return fileName.matches('^[A-Za-z0-9_-]+\\.mp4$') &&
        isOwnedVideoDoc(videoDocIdFromFileName(fileName));
    }

    function isOwnedThumbnail(fileName) {
      return (
        fileName.matches('^thumbnail_[A-Za-z0-9_-]+\\.jpg$') &&
        isOwnedVideoDoc(thumbnailDocIdFromJpgFileName(fileName))
      ) || (
        fileName.matches('^thumbnail_[A-Za-z0-9_-]+\\.png$') &&
        isOwnedVideoDoc(thumbnailDocIdFromJpgFileName(fileName))
      ) || (
        fileName.matches('^thumbnail_[A-Za-z0-9_-]+\\.jpeg$') &&
        isOwnedVideoDoc(thumbnailDocIdFromJpegFileName(fileName))
      );
    }

    match /profilePhotos/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /cvs/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /videos/{videoFileName} {
      allow read: if true;
      allow write: if signedIn() && isOwnedVideoMp4(videoFileName);
    }

    match /thumbnails/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isOwnedThumbnail(fileName);
    }

    match /hls/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
