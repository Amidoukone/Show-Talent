rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /profilePhotos/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /cvs/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /videos/{videoId}.mp4 {
      allow read: if true;
      allow write: if signedIn() &&
        firestore.get(/databases/(default)/documents/videos/$(videoId)).data.uid == request.auth.uid;
    }

    match /thumbnails/{fileName} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /hls/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
