rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function videoDocIdFromFileName(fileName) {
      return fileName[0:fileName.size() - 4];
    }

    function isOwnedVideoMp4(fileName) {
      return fileName.matches('^[A-Za-z0-9_-]+\\.mp4$') &&
        firestore.exists(/databases/(default)/documents/videos/$(videoDocIdFromFileName(fileName))) &&
        firestore.get(/databases/(default)/documents/videos/$(videoDocIdFromFileName(fileName))).data.uid == request.auth.uid;
    }

    match /profilePhotos/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /cvs/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /videos/{videoFileName} {
      allow read: if true;
      allow write: if signedIn() && isOwnedVideoMp4(videoFileName);
    }

    match /thumbnails/{fileName} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /hls/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
